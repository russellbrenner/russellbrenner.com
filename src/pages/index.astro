---
import Layout from '@/layouts/Layout.astro';
import { getCollection } from 'astro:content';
import PostCard from '@/components/PostCard.svelte';
import { getReadTime } from '@/lib/utils/readTime';
import { getPublishedPosts, getPostSlug } from '@/lib/utils/posts';
import { SITE } from '@/config';
import { getLangFlag } from '@/lib/utils/lang';
import { readFileSync } from 'fs';
import { join } from 'path';
import { parseMarkdown } from '@/lib/simple-markdown';

const posts = (await getPublishedPosts()).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featuredPosts = posts.filter((post) => post.data.featured).slice(0, SITE.featuredPostsCount);
const latestPosts = posts.filter((post) => !post.data.featured).slice(0, SITE.latestPostsCount);

const projects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, SITE.homeProjects.count);

const appearances = (await getCollection('appearances'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Layout title="Welcome">
  <!-- 1. Hero Section -->
  <section class="mb-24 lg:mb-32">
    <div class="text-center md:text-left">
      <div
        class="hero-content"
        set:html={(() => {
          try {
            const fullPath = join(process.cwd(), SITE.hero.filePath);
            const markdown = readFileSync(fullPath, 'utf-8');
            return parseMarkdown(markdown.replace('{author}', SITE.author));
          } catch {
            return `<h1>I'm ${SITE.author}, developer and designer.</h1><p>${SITE.homeHeroDescription}</p>`;
          }
        })()}
      />
      <div class="flex flex-wrap justify-center md:justify-start gap-3">
        {
          Object.entries(SITE.social).map(([platform, link]) => (
            <a
              href={link}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`${platform} profile`}
              class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md border border-border text-xs text-muted-foreground hover:text-primary hover:border-primary transition-all no-underline"
            >
              {platform === 'linkedin' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              )}
              {platform === 'github' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
                </svg>
              )}
              <span class="capitalize">{platform}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <div class="flex flex-col gap-24 lg:gap-32">
    <!-- 2. Featured Posts -->
    {
      featuredPosts.length > 0 && (
        <section>
          <div class="flex items-baseline justify-between mb-8 sm:mb-12">
            <h2 class="text-xs font-bold uppercase tracking-[0.2em] text-muted-foreground">
              Featured
            </h2>
            <div class="h-px flex-1 mx-4 sm:mx-8 bg-border opacity-70" />
            <a
              href="/posts"
              class="px-2 py-0.5 rounded-md text-xs font-bold uppercase tracking-widest hover:bg-accent hover:text-primary transition-all no-underline"
            >
              See all posts
            </a>
          </div>
          <div class="grid gap-3 sm:gap-4">
            {featuredPosts.map((post) => (
              <PostCard {post} slug={getPostSlug(post)} readTime={getReadTime(post.body || '')} />
            ))}
          </div>
        </section>
      )
    }

    <!-- 3. Latest Posts -->
    <section>
      <div class="flex items-baseline justify-between mb-8 sm:mb-12">
        <h2 class="text-xs font-bold uppercase tracking-[0.2em] text-muted-foreground">
          Latest Writing
        </h2>
        <div class="h-px flex-1 mx-4 sm:mx-8 bg-border opacity-70"></div>
        <a
          href="/posts"
          class="px-2 py-0.5 rounded-md text-xs font-bold uppercase tracking-widest hover:bg-accent hover:text-primary transition-all no-underline"
          >Writing Archive</a
        >
      </div>
      <div class="grid gap-3 sm:gap-4">
        {
          latestPosts.map((post) => (
            <PostCard {post} slug={getPostSlug(post)} readTime={getReadTime(post.body || '')} />
          ))
        }
      </div>
    </section>

    <!-- 4. Projects -->
    {
      SITE.homeProjects.enabled && projects.length > 0 && (
        <section>
          <div class="flex items-baseline justify-between mb-8 sm:mb-12">
            <h2 class="text-xs font-bold uppercase tracking-[0.2em] text-muted-foreground">
              Projects
            </h2>
            <div class="h-px flex-1 mx-4 sm:mx-8 bg-border opacity-70" />
            <a
              href="/projects"
              aria-label="View all projects"
              class="px-2 py-0.5 rounded-md text-xs font-bold uppercase tracking-widest hover:bg-accent hover:text-primary transition-all no-underline"
            >
              All Projects
            </a>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 lg:gap-6">
            {projects.map((project) => {
              const isExternal = project.data.directLink && !!project.data.link;
              const projectUrl =
                isExternal && project.data.link ? project.data.link : `/projects/${project.id}`;
              const target = isExternal ? '_blank' : '_self';

              return (
                <article class="flex flex-col h-full p-6 rounded-2xl bg-secondary/30 border border-border/50 hover:bg-secondary/50 hover:border-border transition-all duration-300 group">
                  <div class="flex-1">
                    <a
                      href={projectUrl}
                      target={target}
                      rel={isExternal ? 'noopener noreferrer' : undefined}
                      class="no-underline"
                    >
                      <h3 class="text-lg sm:text-xl font-bold leading-tight mb-3 group-hover:text-primary transition-colors">
                        {project.data.title}
                      </h3>
                    </a>

                    {project.data.types && project.data.types.length > 0 && (
                      <div class="flex flex-wrap gap-1.5 mb-3">
                        {project.data.types.map((type) => (
                          <span
                            class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-bold uppercase tracking-wide ${
                              type === 'commercial'
                                ? 'bg-primary/10 text-primary border border-primary/20'
                                : type === 'open-source'
                                  ? 'bg-emerald-500/10 text-emerald-700 dark:text-emerald-300 border border-emerald-500/20'
                                  : 'bg-indigo-500/10 text-indigo-700 dark:text-indigo-300 border border-indigo-500/20'
                            }`}
                          >
                            {type === 'open-source' ? 'Open Source' : type}
                          </span>
                        ))}
                      </div>
                    )}

                    <p class="text-sm text-muted-foreground leading-relaxed mb-4">
                      {project.data.description}
                    </p>

                    <div class="flex flex-wrap gap-2 mb-4">
                      {project.data.tags.slice(0, 3).map((tag) => (
                        <span class="inline-flex items-center px-2 py-1 rounded-md text-xs font-medium bg-background border border-border text-muted-foreground">
                          {tag}
                        </span>
                      ))}
                    </div>
                  </div>

                  <div class="flex items-center gap-3 pt-4 border-t border-border/50">
                    <a
                      href={projectUrl}
                      target={target}
                      rel={isExternal ? 'noopener noreferrer' : undefined}
                      class="inline-flex items-center gap-2 text-sm font-medium text-foreground hover:text-primary transition-colors no-underline"
                    >
                      {isExternal ? 'Visit Site' : 'View Details'}
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <>
                          <path d="M7 7h10v10" />
                          <path d="M7 17 17 7" />
                        </>
                      </svg>
                    </a>

                    {project.data.github && (
                      <a
                        href={project.data.github}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="ml-auto inline-flex items-center gap-2 text-sm font-medium text-muted-foreground hover:text-foreground transition-colors no-underline"
                        aria-label={`GitHub repository for ${project.data.title}`}
                      >
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          width="18"
                          height="18"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                          <path d="M9 18c-4.51 2-5-2-7-2" />
                        </svg>
                        GitHub
                      </a>
                    )}
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      )
    }

    <!-- 5. Talks / Appearances -->
    {appearances.length > 0 && <section>
      <div class="flex items-baseline justify-between mb-8 sm:mb-12">
        <h2 class="text-xs font-bold uppercase tracking-[0.2em] text-muted-foreground">
          Talks & Appearances
        </h2>
        <div class="h-px flex-1 mx-4 sm:mx-8 bg-border opacity-70"></div>
        <a
          href="/appearances"
          class="px-2 py-0.5 rounded-md text-xs font-bold uppercase tracking-widest hover:bg-accent hover:text-primary transition-all no-underline"
          >View appearances</a
        >
      </div>
      <div class="space-y-4 sm:space-y-6">
        {
          appearances.map((item) => (
            <a
              href={item.data.link}
              class="flex items-center justify-between py-3 group no-underline transition-all hover:translate-x-1"
            >
              <div class="flex flex-col">
                <span class="text-xs font-bold uppercase tracking-widest text-muted-foreground mb-1">
                  {item.data.event}
                </span>
                <span class="font-bold text-sm sm:text-base text-foreground group-hover:text-primary transition-colors leading-tight">
                  {item.data.title}
                </span>
              </div>
              <div class="flex items-center gap-4">
                {item.data.lang && item.data.lang !== 'en' && (
                  <span
                    class="inline-flex items-center gap-1.5 px-1.5 py-0.5 rounded bg-secondary/50 text-[10px] font-bold uppercase tracking-tighter text-muted-foreground group-hover:text-foreground transition-colors cursor-help"
                    title={`Language: ${item.data.lang}`}
                  >
                    <span class="text-sm leading-none group-hover:scale-110 transition-transform">
                      {getLangFlag(item.data.lang)}
                    </span>
                    {item.data.lang}
                  </span>
                )}
                <span class="text-xs font-medium text-muted-foreground tabular-nums">
                  {item.data.date.getFullYear()}
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </section>}
  </div>
</Layout>

<style>
  .hero-content :global(h1) {
    font-size: 1.875rem; /* text-3xl */
    line-height: 1.1;
    font-weight: 900; /* font-black */
    letter-spacing: -0.025em; /* tracking-tight */
    margin-bottom: 1rem; /* mb-4 */
    color: var(--color-foreground);
  }

  @media (min-width: 640px) {
    .hero-content :global(h1) {
      font-size: 2.25rem; /* sm:text-4xl */
    }
  }

  @media (min-width: 1024px) {
    .hero-content :global(h1) {
      font-size: 3rem; /* lg:text-5xl */
    }
  }

  @media (min-width: 1920px) {
    .hero-content :global(h1) {
      font-size: 3.75rem; /* 3xl:text-6xl */
    }
  }

  .hero-content :global(p) {
    font-size: 1rem; /* text-base */
    line-height: 1.625; /* leading-relaxed */
    color: var(--color-muted-foreground);
    margin-bottom: 2rem; /* mb-8 */
    max-width: 42rem; /* max-w-2xl */
    margin-left: auto;
    margin-right: auto;
  }

  @media (min-width: 640px) {
    .hero-content :global(p) {
      font-size: 1.125rem; /* sm:text-lg */
    }
  }

  @media (min-width: 768px) {
    .hero-content :global(p) {
      margin-left: 0;
      margin-right: 0;
    }
  }

  @media (min-width: 1024px) {
    .hero-content :global(p) {
      font-size: 1.25rem; /* lg:text-xl */
    }
  }
</style>
